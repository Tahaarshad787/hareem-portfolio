# =============================================================================
# LOCAL: copy → `.env`   PowerShell:  Copy-Item .env.example .env
# Values yahan mat commit karo (`.env` gitignore mein hai)
# =============================================================================
#
# --- A) VITE / CLIENT — is project ka contact form (EmailJS) yahi use karta hai ---
#     `src/env.js` sirf in 4 ko validate karta hai (import.meta.env)
#
VITE_EMAILJS_SERVICE_ID=
#    EmailJS → Email Services → service row → Service ID (service_...)

VITE_EMAILJS_TEMPLATE_ID=
#    EmailJS → Email Templates → Template ID (template_...)
#    Body/To: {{sender_email}} {{message}} {{to_email}} {{reply_to}}

VITE_EMAILJS_PUBLIC_KEY=
#    EmailJS → Account → API keys → Public Key

VITE_RECEIVER_EMAIL=
#    Jis inbox par mail aani ho (template ke To se match)

VITE_LINKEDIN_URL=
#    Hero LinkedIn button — poora URL, maslan https://www.linkedin.com/in/apna-username
#
# =============================================================================
# --- B) PORTFOLIO (Next @ e:\portfolio) JAISA — SERVER / META (VITE prefix NAHI)
#     Ye keys is Vite SPA ke `env.js` mein load NAHI hoti (browser safe).
#     Vercel par phir bhi rakh sakti ho taake baad mein API / Next migrate par same naam hon.
# =============================================================================
#
# RESEND_API_KEY=
#   Resend → https://resend.com → login → left **API Keys** → **Create API Key**
#   naam do (e.g. "portfolio") → copy key (shuru hoti hai: re_...)
#   ⚠ Sirf server / Vercel function mein use karo — kabhi VITE_ mat lagao (leak ho jati hai)
#
# SITE_URL=
#   Production URL, maslan: https://tumhari-site.vercel.app
#   Next portfolio mein optional URL + SEO ke liye
#
# GOOGLE_SITE_VERIFICATION_ID=
#   Google Search Console se meta verification string (optional)
#
# =============================================================================
# VERCEL dashboard → Environment Variables
#   - EmailJS wali 4 lines: Production (aur chaho to Preview) — VITE_ wale
#   - Resend / SITE_URL / Google: bina VITE_ ke (server / build tools ke liye)
# Save ke baad **Redeploy**
# =============================================================================
